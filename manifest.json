{
  "manifest_version": 3,
  "name": "Bookmarks to mymind for X",
  "version": "1.0",
  "description": "Automatically save your X/Twitter bookmarks to your mymind account. Not affiliated with mymind.",
  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*",
    "*://access.mymind.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Bookmarks to mymind for X",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["nunito.woff2", "logo.svg", "x-icon.svg", "x-icon-bg.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
